# ---- Server ----
PORT=4000

# ---- x402 payments (OKX Payment SDK / facilitator) ----
# Set PAYMENTS_ENABLED=false for local development without OKX credentials.
# MUST be true in production or the endpoint will not pass OKX.AI review.
PAYMENTS_ENABLED=true
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# Your X Layer wallet that receives x402 payments (USDT0 on eip155:196)
PAY_TO_ADDRESS=0xYourXLayerWallet
# Price charged per successful execution call
EXECUTE_PRICE_USD=$0.50

# ---- Polymarket execution ----
# Private key of the Polygon wallet that holds USDC and executes trades.
# NEVER commit this. Fund it only with what you are willing to trade.
POLYMARKET_PRIVATE_KEY=
# Polymarket CLOB endpoint
CLOB_API_URL=https://clob.polymarket.com
# Polygon chain id
CHAIN_ID=137
# Funder address (Polymarket proxy wallet holding USDC). Leave empty to use EOA directly.
POLYMARKET_FUNDER_ADDRESS=
# Signature type: 0 = EOA, 1 = Magic/email proxy, 2 = browser proxy wallet
POLYMARKET_SIGNATURE_TYPE=0

# ---- Safety rails ----
# Hard cap on USDC spent per single order
MAX_ORDER_USDC=100
# Hard cap on total USDC spent per UTC day
MAX_DAILY_USDC=500
